# AI Data Operations Platform - Environment Configuration
# Copy this to .env.local and fill in your actual values

# ============================================================================
# SUPABASE - PostgreSQL + RLS + pgvector (UPGRADED STACK)
# ============================================================================
# Get these from https://app.supabase.com/project/[your-project]/settings/api

SUPABASE_URL=https://[your-project].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Public versions for Next.js client
NEXT_PUBLIC_SUPABASE_URL=https://[your-project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct PostgreSQL connection (optional)
DATABASE_URL=postgresql://postgres:[password]@[host]:[port]/postgres

# ============================================================================
# UPSTASH REDIS - Real-time task queue (UPGRADED FROM REDIS)
# ============================================================================
# Get these from https://console.upstash.com

UPSTASH_REDIS_URL=https://default:[token]@[region].upstash.io
UPSTASH_REDIS_TOKEN=[token]
REDIS_URL=redis://localhost:6379  # For local development

# ============================================================================
# TRIGGER.DEV - Background jobs (REPLACES TEMPORAL)
# ============================================================================
# Get these from https://trigger.dev/dashboard

TRIGGER_DEV_API_KEY=tr_[your_api_key]
TRIGGER_DEV_PROJECT_ID=proj_[your_project_id]

# ============================================================================
# N8N - Workflow automation (NEW - Visual workflows)
# ============================================================================

N8N_WEBHOOK_URL=https://n8n.example.com/webhook
N8N_API_URL=https://n8n.example.com/api/v1
N8N_API_KEY=n8n_[your_api_key]

# ============================================================================
# LEGACY - Keep for backward compatibility if needed
# ============================================================================

# Database Configuration (deprecated - use Supabase instead)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=annotation_db
DB_USER=dataops
DB_PASSWORD=dataops_dev_password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis Configuration (deprecated - use Upstash instead)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
REDIS_DB=0

# Temporal Workflow Configuration (deprecated - use Trigger.dev instead)
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=annotation-tasks

# ============================================================================
# RESEND - Transactional email (NEW)
# ============================================================================
# Get this from https://resend.com/api-keys

RESEND_API_KEY=re_[your_api_key]

# ============================================================================
# CLERK - Authentication (NEW)
# ============================================================================
# Get these from https://dashboard.clerk.com

CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ============================================================================
# VERCEL - Deployment (NEW)
# ============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Data Ops Platform
NODE_ENV=development

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

ENVIRONMENT=development
LOG_LEVEL=info
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30

# AWS S3 Configuration (optional)
AWS_REGION=us-east-1
S3_BUCKET=ai-data-ops-dev
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# pgAdmin Configuration (development only)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Grafana Configuration (development only)
GRAFANA_PASSWORD=admin

# Application Secrets
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Feature Flags
ENABLE_ACTIVE_LEARNING=true
ENABLE_DRIFT_DETECTION=true
ENABLE_EXPERT_QUEUE=true
ENABLE_GOLDEN_SET=true

# Quality Thresholds
MIN_AGREEMENT_QUALITY=0.70
MIN_GOLDEN_SET_ACCURACY=0.95
MIN_ANNOTATOR_ACCURACY=0.80
QUALITY_THRESHOLD=0.80

# Consensus Configuration
CONSENSUS_METHOD=weighted_vote
MIN_CONSENSUS_AGREEMENT=0.50
EXPERT_TIEBREAK_TIMEOUT_MINUTES=60

# Active Learning
ACTIVE_LEARNING_BUDGET=50
ACTIVE_LEARNING_ENTROPY_THRESHOLD=0.5
ACTIVE_LEARNING_RUN_SCHEDULE="0 8 * * *"

# Task Assignment
MAX_TASKS_PER_ANNOTATOR=20
MIN_ANNOTATOR_ACCURACY=0.75

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=/var/log/ai-data-ops/app.log

# Development/Testing
DEBUG=false
TESTING=false

# ============================================================================
# OPTIONAL: INTEGRATIONS
# ============================================================================

# Slack notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/[your/webhook/url]
SLACK_BOT_TOKEN=xoxb-[your_token]

# Sentry error tracking (optional)
SENTRY_DSN=https://[key]@[account].ingest.sentry.io/[project]

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# LOCAL DEVELOPMENT:
# 1. Copy this file to .env.local
# 2. Fill in Supabase, Redis (Upstash), Trigger.dev, Resend, Clerk keys
# 3. Run: make setup
# 4. Run: make docker-up (for local Postgres + Redis)
#
# PRODUCTION:
# - Use strong, unique values for all secrets
# - Store in your hosting platform's environment UI (Vercel)
# - Enable monitoring/alerting integrations
#
# SUPABASE SETUP:
# - Run migrations: supabase migration up
# - Enable RLS policies
# - pgvector extension must be enabled
#
